# GEMINI_API_KEY: Required for Gemini AI API calls (receipt OCR + insights).
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ---- Wallet Assistant (Ollama) ----
# The assistant is grounded on your REAL data; it just needs a model to phrase answers.
#
# Option A — Ollama Cloud (default). Create a FREE key at https://ollama.com/settings/keys
OLLAMA_HOST="https://ollama.com"
OLLAMA_API_KEY="MY_OLLAMA_CLOUD_KEY"
OLLAMA_MODEL="gpt-oss:120b"
#
# Option B — Local Ollama (no key needed). Install from https://ollama.com, then:
#   ollama pull llama3.2   &&   ollama serve
# and set:
#   OLLAMA_HOST="http://localhost:11434"
#   OLLAMA_MODEL="llama3.2"
#   (leave OLLAMA_API_KEY unset)
